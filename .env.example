# Auth secrets — DO NOT commit real values. Copy to `.env` and fill in strong secrets.
# Access token signing secret (use a long random string, e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-access-secret-change-me

# Refresh token signing secret (use a DIFFERENT long random string).
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Token TTLs (jsonwebtoken expiresIn format).
ACCESS_TTL=15m
REFRESH_TTL=7d

# bcrypt cost factor (>=12 recommended for production).
HASH_COST=12

# Clock tolerance for JWT verification (seconds) to absorb clock skew.
JWT_CLOCK_TOLERANCE=5

# Server bind config.
PORT=3000
HOST=0.0.0.0
